{
  "name": "my-space",
  "productName": "My SPACE",
  "version": "0.1.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "pack": "vite build && cd dist && zip -r ../my-space-$(node -p \"require('../package.json').version\").zip . && echo '✓ packed'",
    "release:patch": "node scripts/bump.js patch && npm run pack",
    "release:minor": "node scripts/bump.js minor && npm run pack",
    "release:major": "node scripts/bump.js major && npm run pack",
    "test": "vitest run"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@electric-sql/pglite": "^0.5.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.5.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/chrome": "^0.1.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
